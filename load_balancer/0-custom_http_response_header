#!/usr/bin/env bash
# Configures nginx with an X-Served-By header using the server hostname

# Update package list and install nginx
apt-get update -y
apt-get install -y nginx

# Create a simple index page (reuse the Holberton text for consistency)
echo 'Holberton School for the win!' > /var/www/html/index.html

# Add custom header X-Served-By with the hostname value
# This inserts the header inside the main location / block
sed -i '/location \/ {/a \    add_header X-Served-By $hostname;' /etc/nginx/sites-available/default

# Restart nginx without using systemctl
service nginx restart

